      "parameters": {
        "jsCode": "// Define time constants\nconst now = new Date();\nconst oneDay = 24 * 60 * 60 * 1000; // 24 hours in milliseconds\n\n// Filter the leads and return ONLY the ones ready to be emailed\nreturn $input.all().filter(item => {\n  const step = item.json[\"Current Step\"];\n  const lastActionStr = item.json[\"Last Action Date\"];\n  const status = item.json[\"Bounce/Reply Status\"];\n\n  // 0. SAFETY CHECK\n  // If status is Bounced, Replied, or Completed, never email them again.\n  if ([\"Bounced\", \"Replied\", \"Completed\", \"Skipped\"].includes(status)) {\n    return false;\n  }\n\n  // RULE 1: Initial Outreach (New Leads)\n  // Condition: Step is \"Initial Outreach\" AND Date is Empty (never sent)\n  if (step === \"Initial Outreach\" && !lastActionStr) {\n    return true;\n  }\n\n  // RULE 2: First Follow Up\n  // Condition: Step is \"First Follow up\" AND it has been > 24 hours since last email\n  if (step === \"First Follow up\" && lastActionStr) {\n    const lastActionTime = new Date(lastActionStr).getTime();\n    // Check if valid date (not \"Invalid Date\") and if 24h has passed\n    if (!isNaN(lastActionTime) && (now.getTime() - lastActionTime > oneDay)) {\n      return true;\n    }\n  }\n\n  // RULE 3: Last Follow Up\n  // Condition: Step is \"Last Follow up\" AND it has been > 48 hours since last email\n  if (step === \"Last Follow up\" && lastActionStr) {\n    const lastActionTime = new Date(lastActionStr).getTime();\n    // Check if 48h has passed\n    if (!isNaN(lastActionTime) && (now.getTime() - lastActionTime > (oneDay * 2))) {\n      return true;\n    }\n  }\n\n  // If no rules matched, filter this lead out\n  return false;\n});"
      },

    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const rawFrom = item.json[\"From\"];\n  \n  // 1. Extract email using Regex (Finds text between < and >)\n  // If no brackets found (rare), it uses the whole string.\n  const emailMatch = rawFrom.match(/<(.+)>/);\n  const cleanEmail = emailMatch ? emailMatch[1] : rawFrom;\n\n  // 2. Output the clean email\n  item.json.cleanEmail = cleanEmail;\n  item.json.statusUpdate = \"Replied\";\n}\n\nreturn $input.all();"
      },
